import heapq
import numpy as np

# Heuristic Function (Manhattan Distance)
def heuristic(state, goal):
    return sum(
        abs(b // 3 - g // 3) + abs(b % 3 - g % 3)
        for i in range(1, 9)
        for b, g in [(state.index(i), goal.index(i))]
    )

# Generate Neighbour States
def get_neighbours(state):
    neighbours = []
    zero_index = state.index(0)
    row, col = zero_index // 3, zero_index % 3

    moves = [(-1, 0), (1, 0), (0, -1), (0, 1)]  # Up, Down, Left, Right

    for dr, dc in moves:
        new_row, new_col = row + dr, col + dc

        if 0 <= new_row < 3 and 0 <= new_col < 3:
            new_index = new_row * 3 + new_col
            new_state = list(state)

            # Swap zero with new position
            new_state[zero_index], new_state[new_index] = \
                new_state[new_index], new_state[zero_index]

            neighbours.append(tuple(new_state))

    return neighbours

# A* Algorithm
def solve_puzzle(start, goal):
    pq = [(heuristic(start, goal), 0, start, [])]
    visited = set()

    while pq:
        _, moves, state, path = heapq.heappop(pq)

        if state == goal:
            return path + [state]

        if state in visited:
            continue

        visited.add(state)

        for neighbour in get_neighbours(state):
            heapq.heappush(
                pq,
                (moves + 1 + heuristic(neighbour, goal),
                 moves + 1,
                 neighbour,
                 path + [state])
            )

    return None

# Start and Goal States
start_state = (2, 8, 3, 1, 6, 4, 7, 0, 5)
goal_state = (1, 2, 3, 8, 0, 4, 7, 6, 5)

solution = solve_puzzle(start_state, goal_state)

if solution:
    for step in solution:
        print(np.array(step).reshape(3, 3))
        print()
else:
    print("No solution found")
