b = [" "]*9

def win(p):
    return any(b[i]==b[j]==b[k]==p for i,j,k in
               [(0,1,2),(3,4,5),(6,7,8),
                (0,3,6),(1,4,7),(2,5,8),
                (0,4,8),(2,4,6)])

p = "X"
for _ in range(9):
    print(b[0:3], b[3:6], b[6:9])
    m = int(input("Enter (0-8): "))
    if b[m] == " ":
        b[m] = p
        if win(p):
            print(p, "wins"); break
        p = "O" if p=="X" else "X"
    else:
        print("Invalid")
